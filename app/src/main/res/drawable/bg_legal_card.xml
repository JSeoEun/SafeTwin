<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 배경 색 -->
    <solid android:color="#FFFFFF" />

    <!-- 모서리 둥글게 -->
    <corners android:radius="16dp" />

    <!-- 테두리 (살짝만) -->
    <stroke
        android:width="1dp"
        android:color="#E2E8F0" />

    <!-- 그림자 느낌 (padding으로 여백) -->
    <padding
        android:left="0dp"
        android:top="0dp"
        android:right="0dp"
        android:bottom="0dp"/>

</shape>