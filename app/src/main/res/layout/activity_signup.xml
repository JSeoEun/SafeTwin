<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF0FA">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        android:gravity="center">

    <!-- 상단 로고 섹션 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="30dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:text="🛡️"
                android:textSize="32sp"
                android:layout_marginEnd="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Safe"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#F1640C"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:text="Twin"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <TextView
            android:text="안전한 사업장 관리를 위한 스마트 솔루션"
            android:textSize="14sp"
            android:textColor="#666666"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
    <LinearLayout
        android:id="@+id/signupCard"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_auth_card"
        android:padding="28dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 로그인 / 회원가입 탭 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bg_tab_container">

            <TextView
                android:id="@+id/loginTab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="로그인"
                android:textSize="13sp"
                android:textColor="#6B7C93"
                android:gravity="center" />

            <TextView
                android:id="@+id/signupTab"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="회원가입"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#1F2A44"
                android:gravity="center"
                android:background="@drawable/bg_tab_selected" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="사업자 등록번호"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#344054"
            android:layout_marginTop="26dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/businessNumberEditText"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_input_default"
                android:hint="000-00-00000"
                android:textColor="#1F2A44"
                android:textColorHint="#98A2B3"
                android:textSize="14sp"
                android:paddingHorizontal="12dp"
                android:inputType="number" />

            <TextView
                android:id="@+id/verifyStatusText"
                android:layout_width="78dp"
                android:layout_height="match_parent"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="✓ 확인됨"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#168A4A"
                android:background="@drawable/bg_verified_box"
                android:visibility="gone" />
        </LinearLayout>

        <TextView
            android:id="@+id/businessCheckGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ 건설업 · 소규모 사업장으로 확인"
            android:textSize="11sp"
            android:textColor="#168A4A"
            android:layout_marginTop="8dp"
            android:visibility="gone"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이메일"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#344054"
            android:layout_marginTop="20dp" />

        <EditText
            android:id="@+id/emailEditText"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_default"
            android:hint="example@company.com"
            android:textColor="#1F2A44"
            android:textColorHint="#98A2B3"
            android:textSize="14sp"
            android:paddingHorizontal="12dp"
            android:inputType="textEmailAddress" />

        <Button
            android:id="@+id/signupCompleteButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="가입 완료"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_primary_button" />

    </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
