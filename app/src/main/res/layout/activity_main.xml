<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F6FB">

    <!-- 🔵 메인 화면 (Fragment 들어가는 곳) -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 🟡 사이드바 -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp">

        <!-- 앱 이름 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafeTwin"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1E4DCB"
            android:layout_marginBottom="20dp" />

        <!-- 메뉴 1 -->
        <TextView
            android:id="@+id/menuDash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="대시보드"
            android:textSize="16sp"
            android:padding="12dp" />

        <!-- 메뉴 2 -->
        <TextView
            android:id="@+id/menuAnalysis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="안전 분석"
            android:textSize="16sp"
            android:padding="12dp" />

        <!-- 메뉴 3 -->
        <TextView
            android:id="@+id/menuDigitalTwin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="탑뷰 시각화"
            android:textSize="16sp"
            android:padding="12dp" />

        <!-- 메뉴 4 -->
        <TextView
            android:id="@+id/menuAfterCare"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="통계 &amp; 사후관리"
            android:textSize="16sp"
            android:padding="12dp" />

        <!-- 메뉴 5 -->
        <TextView
            android:id="@+id/menuLegal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="법적 증빙"
            android:textSize="16sp"
            android:padding="12dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>