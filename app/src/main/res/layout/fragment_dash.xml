<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/dashboardRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F6FB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SafeTwin"
            android:textColor="#1E4DCB"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="안전 현황 요약"
            android:textColor="#7A8AA0"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />

        <!-- 안전 점수 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="안전 점수"
                android:textColor="#6B7C93"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="82점"
                android:textColor="#0B1736"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+5 전주 대비"
                android:textColor="#008A3D"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 위험 탐지 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이번 주 위험 탐지"
                android:textColor="#6B7C93"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7건"
                android:textColor="#0B1736"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="-2 전주 대비"
                android:textColor="#008A3D"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 미조치 항목 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="미조치 항목"
                android:textColor="#6B7C93"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3개"
                android:textColor="#0B1736"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+1 전주 대비"
                android:textColor="#D93025"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 교육 완료율 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="교육 완료율"
                android:textColor="#6B7C93"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="94%"
                android:textColor="#0B1736"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+8 전주 대비"
                android:textColor="#008A3D"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 최근 분석 기록 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="최근 분석 기록"
                android:textColor="#0B1736"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="1동 창고  |  05.01  |  주의\n지게차 안전거리 표식 불량"
                android:textColor="#26364D"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="야적장 A구역  |  04.29  |  고위험\n보호구 미착용 · 출입통제 미비"
                android:textColor="#26364D"
                android:textSize="14sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="2동 작업장  |  04.27  |  양호\n정리정돈 미흡"
                android:textColor="#26364D"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- 안전 등급 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="안전 등급 현황"
                android:textColor="#0B1736"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="82 / 100"
                android:textColor="#1D4ED8"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="등급 B+"
                android:textColor="#1E40AF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전월 77점 / 목표 90점"
                android:textColor="#64748B"
                android:textSize="13sp"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- TBM 가이드 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_tbm"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘의 TBM 가이드"
                android:textColor="#0B1736"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="지게차 작업 · 작업반경 내 작업자 접근 금지, 적재 높이 1.8m 초과 금지"
                android:textColor="#334155"
                android:textSize="14sp"
                android:lineSpacingExtra="4dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>