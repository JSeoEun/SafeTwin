<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- 카드 공통 -->
    <style name="DashboardCard">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">116dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="android:background">@drawable/card_bg</item>
        <item name="android:padding">14dp</item>
        <item name="android:orientation">vertical</item>
    </style>


    <!-- 카드 숫자 -->
    <style name="CardNumber">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#0F172A</item>
    </style>


    <!-- 카드 설명 -->
    <style name="CardLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#64748B</item>
    </style>


    <!-- 상승 (초록) -->
    <style name="CardPositive">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#16A34A</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">6dp</item>
    </style>


    <!-- 하락 (빨강) -->
    <style name="CardNegative">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">#DC2626</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginTop">6dp</item>
    </style>


    <!-- 아이콘 색상 -->
    <style name="CardIconBlue">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#1D4ED8</item>
    </style>

    <style name="CardIconOrange">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#EA580C</item>
    </style>

    <style name="CardIconRed">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#DC2626</item>
    </style>

    <style name="CardIconGreen">
        <item name="android:layout_width">26dp</item>
        <item name="android:layout_height">26dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#16A34A</item>
    </style>


    <!-- 테이블 행 -->
    <style name="TableRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">#334155</item>
        <item name="android:padding">6dp</item>
    </style>

</resources>